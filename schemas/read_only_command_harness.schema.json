{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/durable-slice-workflow/read_only_command_harness.schema.json",
  "title": "Read-Only Command Harness Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "status",
    "purpose",
    "default_policy",
    "commands"
  ],
  "properties": {
    "schema_version": { "const": "v1.repo_agnostic_read_only_command_harness.1" },
    "contract_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["active", "draft"] },
    "purpose": { "type": "string", "minLength": 16 },
    "default_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "forbid_shell",
        "forbid_shell_metacharacters",
        "compact_mode_tokens",
        "forbidden_argv_tokens",
        "snapshot_roots",
        "ignore_dirs",
        "timeout_seconds"
      ],
      "properties": {
        "forbid_shell": { "const": true },
        "forbid_shell_metacharacters": { "const": true },
        "compact_mode_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_argv_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "snapshot_roots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "ignore_dirs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command_id",
          "cwd",
          "argv",
          "expected_exit_codes",
          "compact_mode"
        ],
        "properties": {
          "command_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "cwd": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$))(?!.*\\\\).*$"
          },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "expected_exit_codes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 0 }
          },
          "compact_mode": { "type": "boolean" }
        }
      }
    }
  }
}
