{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/durable-slice-workflow/methodology.schema.json",
  "title": "Durable Slice Build Workflow Methodology",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "methodology_id",
    "schema_version",
    "created_at_utc",
    "status",
    "intended_use",
    "not_intended_for",
    "purpose",
    "non_negotiable_principles",
    "artifact_taxonomy",
    "index_architecture_and_layering",
    "minimum_mapping_helper_and_validator_suite",
    "generic_script_architecture",
    "slice_lifecycle",
    "slice_packet_contract_template",
    "refresh_decision_contract",
    "validator_design",
    "focused_test_strategy",
    "evidence_chain",
    "commit_discipline",
    "build_stage_prompt_structure",
    "portability_notes",
    "non_agnostic_instantiation_boundaries",
    "success_metrics",
    "one_page_summary"
  ],
  "properties": {
    "methodology_id": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "intended_use": { "type": "string", "minLength": 1 },
    "not_intended_for": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "purpose": { "type": "string", "minLength": 1 },
    "non_negotiable_principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["principle_id", "rule", "reason", "implementation"]
      }
    },
    "starter_kit_artifacts": {
      "type": "object",
      "required": [
        "canonical_source",
        "quickstart",
        "human_entrypoints",
        "schemas",
        "starter_validator",
        "entrypoint_renderer",
        "minimal_example",
        "realistic_small_example",
        "canonicalization_rule"
      ],
      "additionalProperties": true
    }
  }
}
