{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan Note",
  "type": "object",
  "required": ["schema_version", "plan_note_id", "created_at", "status"],
  "properties": {
    "schema_version": { "const": "v1.plan_note.1" },
    "plan_note_id": { "type": "string", "pattern": "^plan_note_[a-z0-9_]+_[0-9]{8}$" },
    "created_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "status": { "type": "string", "enum": ["active", "draft", "superseded"] },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
