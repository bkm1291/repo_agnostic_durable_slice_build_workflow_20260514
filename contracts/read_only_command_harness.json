{
  "schema_version": "v1.repo_agnostic_read_only_command_harness.1",
  "contract_id": "repo_agnostic_read_only_command_harness_20260514",
  "status": "active",
  "purpose": "Define safe, compact commands that can be validated or executed under a before/after file snapshot so status-oriented checks stay read-only.",
  "default_policy": {
    "forbid_shell": true,
    "forbid_shell_metacharacters": true,
    "compact_mode_tokens": [
      "--summary-only",
      "--check",
      "-q"
    ],
    "forbidden_argv_tokens": [
      "--write",
      "--force",
      "--delete",
      "--output-yaml",
      "--receipt",
      "--apply",
      "--in-place"
    ],
    "snapshot_roots": [
      "."
    ],
    "compare_git_porcelain_before_after": true,
    "stdout_stderr_secret_scan": true,
    "secret_scan_patterns": [
      {
        "name": "private_key_block",
        "pattern": "-----BEGIN [A-Z ]*PRIVATE KEY-----"
      },
      {
        "name": "aws_access_key",
        "pattern": "\\bAKIA[0-9A-Z]{16}\\b"
      },
      {
        "name": "bearer_token",
        "pattern": "(?i)\\bbearer\\s+[A-Za-z0-9._~+/=-]{16,}"
      },
      {
        "name": "secret_assignment",
        "pattern": "(?i)\\b(password|passwd|api[_-]?key|secret|token)\\s*[:=]\\s*['\\\"]?[A-Za-z0-9._~+/=-]{8,}"
      }
    ],
    "ignore_dirs": [
      ".git",
      ".mypy_cache",
      ".pytest_cache",
      ".ruff_cache",
      "__pycache__"
    ],
    "timeout_seconds": 30
  },
  "commands": [
    {
      "command_id": "render_entrypoints_check",
      "cwd": ".",
      "argv": [
        "{python}",
        "scripts/render_canonical_entrypoints.py",
        "--check"
      ],
      "expected_exit_codes": [
        0
      ],
      "compact_mode": true
    },
    {
      "command_id": "validate_low_token_workflow",
      "cwd": ".",
      "argv": [
        "{python}",
        "scripts/validate_low_token_workflow.py",
        "--summary-only"
      ],
